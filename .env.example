# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it contains secrets.

# The title of your application
VITE_APP_TITLE="Mark Your Day-Off"

# Your deployed Google Apps Script Web App URL
# Get this from: Extensions > Apps Script > Deploy > Manage deployments
VITE_GOOGLE_APPS_SCRIPT_URL=

# PIN used to unlock admin features (Manage Access, Delete Records)
# Use a strong alphanumeric PIN — this is the only thing protecting admin access
# Example: MD1431
VITE_ADMIN_PIN=
